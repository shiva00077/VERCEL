# Filename: .gitignore

# =========================
# Node.js
# =========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# =========================
# Environment variables
# =========================
.env
.env.*
backend/.env
frontend/.env

# =========================
# Build files (React)
# =========================
frontend/build/
frontend/dist/
dist/

# =========================
# Logs
# =========================
logs/
*.log

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# IDE / Editor
# =========================
.vscode/
.idea/
*.swp

# =========================
# Docker (optional)
# =========================
*.pid
*.seed
*.pid.lock

# =========================
# Coverage / Testing
# =========================
coverage/

# =========================
# Temporary files
# =========================
tmp/
temp/